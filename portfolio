<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Soboure BELLO — Data Scientist · Ingénieur MAM</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --blue: #1a56db;
    --blue-light: #3b82f6;
    --blue-pale: #eff6ff;
    --blue-mid: #dbeafe;
    --dark: #0f172a;
    --gray-900: #1e293b;
    --gray-700: #334155;
    --gray-500: #64748b;
    --gray-300: #cbd5e1;
    --gray-100: #f1f5f9;
    --white: #ffffff;
    --accent: #1a56db;
    --nav-h: 68px;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { font-family: 'Inter', sans-serif; background: var(--white); color: var(--gray-900); line-height: 1.6; }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    height: var(--nav-h);
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--gray-100);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 5vw;
  }
  .nav-logo { font-family: 'DM Serif Display', serif; font-size: 1.25rem; color: var(--dark); letter-spacing: -0.02em; }
  .nav-logo span { color: var(--blue); }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a { font-size: 0.875rem; font-weight: 500; color: var(--gray-700); text-decoration: none; transition: color .2s; }
  .nav-links a:hover { color: var(--blue); }
  .nav-cta { background: var(--blue); color: var(--white) !important; padding: 0.5rem 1.25rem; border-radius: 6px; font-weight: 600 !important; transition: background .2s !important; }
  .nav-cta:hover { background: #1d4ed8 !important; }
  .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; background: none; border: none; }
  .hamburger span { display: block; width: 24px; height: 2px; background: var(--dark); border-radius: 2px; transition: all .3s; }

  /* ── HERO ── */
  #hero {
    min-height: 100vh;
    padding-top: var(--nav-h);
    display: flex; align-items: center;
    background: linear-gradient(135deg, #f8faff 0%, #eff6ff 50%, #f0f9ff 100%);
    position: relative; overflow: hidden;
  }
  #hero::before {
    content: '';
    position: absolute; top: -120px; right: -120px;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(59,130,246,0.12) 0%, transparent 70%);
    pointer-events: none;
  }
  #hero::after {
    content: '';
    position: absolute; bottom: -80px; left: -80px;
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(26,86,219,0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-inner {
    max-width: 1200px; margin: 0 auto; padding: 5rem 5vw;
    display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: var(--blue-mid); color: var(--blue); border-radius: 100px;
    padding: 0.35rem 1rem; font-size: 0.8rem; font-weight: 600;
    margin-bottom: 1.5rem; letter-spacing: 0.04em;
  }
  .hero-badge::before { content: '●'; font-size: 0.6rem; }
  h1 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2.5rem, 5vw, 3.8rem);
    color: var(--dark); line-height: 1.1; letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }
  h1 .name-accent { color: var(--blue); }
  .hero-tagline {
    font-size: 1.1rem; font-weight: 500; color: var(--gray-500);
    margin-bottom: 1.5rem; letter-spacing: -0.01em;
  }
  .hero-tagline strong { color: var(--gray-700); }
  .hero-desc { font-size: 1rem; color: var(--gray-700); line-height: 1.75; margin-bottom: 2rem; }
  .hero-meta { display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 2rem; }
  .hero-meta-item { display: flex; align-items: center; gap: 0.4rem; font-size: 0.875rem; color: var(--gray-500); }
  .hero-meta-item .icon { font-size: 1rem; }
  .hero-btns { display: flex; flex-wrap: wrap; gap: 1rem; }
  .btn-primary {
    background: var(--blue); color: var(--white);
    padding: 0.875rem 2rem; border-radius: 8px; font-weight: 600; font-size: 0.9rem;
    text-decoration: none; transition: all .2s; display: inline-flex; align-items: center; gap: 0.5rem;
    box-shadow: 0 4px 14px rgba(26,86,219,0.3);
  }
  .btn-primary:hover { background: #1d4ed8; transform: translateY(-1px); box-shadow: 0 8px 20px rgba(26,86,219,0.35); }
  .btn-secondary {
    background: var(--white); color: var(--gray-700);
    padding: 0.875rem 2rem; border-radius: 8px; font-weight: 600; font-size: 0.9rem;
    text-decoration: none; transition: all .2s; display: inline-flex; align-items: center; gap: 0.5rem;
    border: 1.5px solid var(--gray-300);
  }
  .btn-secondary:hover { border-color: var(--blue); color: var(--blue); transform: translateY(-1px); }
  .hero-img-wrap {
    display: flex; justify-content: center; align-items: center; position: relative;
  }
  .hero-img-bg {
    width: 340px; height: 400px; border-radius: 24px;
    background: linear-gradient(145deg, var(--blue) 0%, #1d4ed8 100%);
    position: relative; overflow: hidden;
    box-shadow: 0 24px 60px rgba(26,86,219,0.3);
  }
  .hero-img-bg img {
    width: 100%; height: 100%; object-fit: cover; object-position: top center;
    mix-blend-mode: luminosity; opacity: 0.92;
    transition: opacity .3s;
  }
  .hero-img-bg:hover img { opacity: 1; mix-blend-mode: normal; }
  .hero-img-card {
    position: absolute; bottom: -20px; left: -30px;
    background: var(--white); border-radius: 14px; padding: 1rem 1.25rem;
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
    display: flex; align-items: center; gap: 0.75rem;
  }
  .hero-img-card-icon { font-size: 1.8rem; }
  .hero-img-card-text { font-size: 0.78rem; font-weight: 600; color: var(--dark); }
  .hero-img-card-sub { font-size: 0.7rem; color: var(--gray-500); }
  .hero-stats {
    position: absolute; top: -20px; right: -30px;
    background: var(--white); border-radius: 14px; padding: 1rem 1.25rem;
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
    text-align: center;
  }
  .hero-stats-num { font-family: 'DM Serif Display', serif; font-size: 1.8rem; color: var(--blue); }
  .hero-stats-label { font-size: 0.72rem; font-weight: 600; color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.05em; }

  /* ── SECTIONS ── */
  section { padding: 5rem 5vw; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-tag {
    display: inline-block; background: var(--blue-mid); color: var(--blue);
    font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0.3rem 0.9rem; border-radius: 100px; margin-bottom: 1rem;
  }
  h2 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(1.8rem, 3.5vw, 2.6rem); color: var(--dark);
    letter-spacing: -0.03em; margin-bottom: 0.5rem;
  }
  .section-sub { font-size: 1rem; color: var(--gray-500); margin-bottom: 3rem; max-width: 560px; }

  /* ── ABOUT ── */
  #about { background: var(--white); }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
  .about-text p { color: var(--gray-700); font-size: 0.975rem; line-height: 1.8; margin-bottom: 1rem; }
  .about-atouts { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1.5rem; }
  .atout-card {
    background: var(--gray-100); border-radius: 10px; padding: 1rem 1.25rem;
    border-left: 3px solid var(--blue);
  }
  .atout-icon { font-size: 1.4rem; margin-bottom: 0.4rem; }
  .atout-title { font-weight: 600; font-size: 0.875rem; color: var(--dark); margin-bottom: 0.2rem; }
  .atout-desc { font-size: 0.8rem; color: var(--gray-500); }
  .about-links { display: flex; flex-direction: column; gap: 0.75rem; }
  .contact-item {
    display: flex; align-items: center; gap: 0.75rem;
    padding: 0.875rem 1.25rem; background: var(--gray-100); border-radius: 10px;
    text-decoration: none; color: var(--gray-700); font-size: 0.9rem; font-weight: 500;
    transition: all .2s;
  }
  .contact-item:hover { background: var(--blue-mid); color: var(--blue); transform: translateX(4px); }
  .contact-icon { font-size: 1.2rem; width: 28px; text-align: center; }
  .lang-row { display: flex; gap: 1rem; margin-top: 1rem; }
  .lang-pill {
    padding: 0.4rem 1rem; background: var(--white); border: 1.5px solid var(--gray-300);
    border-radius: 100px; font-size: 0.82rem; font-weight: 600; color: var(--gray-700);
  }

  /* ── FORMATION ── */
  #formation { background: var(--gray-100); }
  .timeline { position: relative; padding-left: 2rem; }
  .timeline::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0;
    width: 2px; background: linear-gradient(to bottom, var(--blue), var(--blue-light), transparent);
  }
  .timeline-item { position: relative; margin-bottom: 2rem; padding-left: 1.5rem; }
  .timeline-dot {
    position: absolute; left: -2.25rem; top: 0.4rem;
    width: 14px; height: 14px; border-radius: 50%;
    background: var(--blue); border: 3px solid var(--white);
    box-shadow: 0 0 0 2px var(--blue);
  }
  .timeline-date { font-size: 0.78rem; font-weight: 600; color: var(--blue); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.35rem; }
  .timeline-title { font-weight: 700; font-size: 1rem; color: var(--dark); }
  .timeline-org { font-size: 0.875rem; color: var(--blue); font-weight: 600; margin-bottom: 0.5rem; }
  .timeline-desc { font-size: 0.875rem; color: var(--gray-700); line-height: 1.7; }
  .timeline-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.75rem; }
  .tag {
    background: var(--white); color: var(--gray-700); font-size: 0.75rem; font-weight: 500;
    padding: 0.25rem 0.75rem; border-radius: 100px; border: 1px solid var(--gray-300);
  }
  .cert-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 2rem; }
  .cert-card {
    background: var(--white); border-radius: 12px; padding: 1.25rem;
    border-left: 4px solid var(--blue); box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }
  .cert-title { font-weight: 700; font-size: 0.9rem; color: var(--dark); }
  .cert-org { font-size: 0.8rem; color: var(--blue); font-weight: 600; }
  .cert-date { font-size: 0.75rem; color: var(--gray-500); margin-top: 0.25rem; }

  /* ── COMPÉTENCES ── */
  #competences { background: var(--white); }
  .skills-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  .skill-group { }
  .skill-group-title { font-weight: 700; font-size: 0.875rem; color: var(--dark); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 2px solid var(--blue-mid); }
  .skill-item { display: flex; flex-direction: column; margin-bottom: 0.875rem; }
  .skill-header { display: flex; justify-content: space-between; margin-bottom: 0.35rem; }
  .skill-name { font-size: 0.875rem; font-weight: 500; color: var(--gray-700); }
  .skill-pct { font-size: 0.78rem; font-family: 'JetBrains Mono', monospace; color: var(--blue); font-weight: 600; }
  .skill-bar { height: 6px; background: var(--gray-100); border-radius: 100px; overflow: hidden; }
  .skill-fill { height: 100%; background: linear-gradient(90deg, var(--blue), var(--blue-light)); border-radius: 100px; }
  .tools-cloud { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.75rem; }
  .tool-badge {
    background: var(--blue-pale); color: var(--blue); font-size: 0.78rem; font-weight: 600;
    padding: 0.3rem 0.8rem; border-radius: 6px; font-family: 'JetBrains Mono', monospace;
  }

  /* ── EXPÉRIENCES ── */
  #experiences { background: var(--gray-100); }
  .exp-card {
    background: var(--white); border-radius: 16px; padding: 2rem;
    margin-bottom: 1.5rem; border: 1px solid var(--gray-100);
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
    transition: box-shadow .2s, transform .2s;
  }
  .exp-card:hover { box-shadow: 0 8px 30px rgba(0,0,0,0.08); transform: translateY(-2px); }
  .exp-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.5rem; }
  .exp-company { font-weight: 700; font-size: 1.05rem; color: var(--dark); }
  .exp-role { font-size: 0.875rem; color: var(--blue); font-weight: 600; }
  .exp-date { font-size: 0.78rem; background: var(--blue-mid); color: var(--blue); padding: 0.3rem 0.75rem; border-radius: 100px; font-weight: 600; white-space: nowrap; }
  .exp-missions { list-style: none; }
  .exp-missions li { font-size: 0.875rem; color: var(--gray-700); line-height: 1.7; padding-left: 1.2rem; position: relative; margin-bottom: 0.4rem; }
  .exp-missions li::before { content: '→'; position: absolute; left: 0; color: var(--blue); font-weight: 700; }
  .exp-link { display: inline-flex; align-items: center; gap: 0.4rem; color: var(--blue); font-size: 0.8rem; font-weight: 600; text-decoration: none; margin-top: 0.75rem; transition: gap .2s; }
  .exp-link:hover { gap: 0.7rem; }

  /* ── PROJETS ── */
  #projets { background: var(--white); }
  .proj-filter { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem; }
  .filter-btn {
    padding: 0.4rem 1rem; border-radius: 100px; border: 1.5px solid var(--gray-300);
    background: none; color: var(--gray-700); font-size: 0.82rem; font-weight: 600;
    cursor: pointer; transition: all .2s;
  }
  .filter-btn.active, .filter-btn:hover { border-color: var(--blue); background: var(--blue); color: var(--white); }
  .proj-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  .proj-card {
    background: var(--white); border: 1.5px solid var(--gray-100); border-radius: 16px;
    padding: 1.75rem; transition: all .2s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }
  .proj-card:hover { border-color: var(--blue-light); box-shadow: 0 8px 30px rgba(26,86,219,0.1); transform: translateY(-3px); }
  .proj-type {
    display: inline-block; font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; padding: 0.25rem 0.75rem; border-radius: 100px; margin-bottom: 0.75rem;
  }
  .proj-type.ml { background: #fef3c7; color: #d97706; }
  .proj-type.dl { background: #fce7f3; color: #db2777; }
  .proj-type.de { background: #d1fae5; color: #059669; }
  .proj-type.bi { background: #ede9fe; color: #7c3aed; }
  .proj-type.saas { background: var(--blue-mid); color: var(--blue); }
  .proj-type.recherche { background: #fdf4ff; color: #9333ea; }
  .proj-title { font-weight: 700; font-size: 1rem; color: var(--dark); margin-bottom: 0.5rem; }
  .proj-desc { font-size: 0.875rem; color: var(--gray-700); line-height: 1.7; margin-bottom: 1rem; }
  .proj-metric {
    display: inline-flex; align-items: center; gap: 0.3rem;
    background: #d1fae5; color: #059669; font-size: 0.78rem; font-weight: 700;
    padding: 0.2rem 0.6rem; border-radius: 100px; margin-bottom: 1rem;
  }
  .proj-techs { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .proj-tech {
    font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; font-weight: 500;
    background: var(--gray-100); color: var(--gray-700); padding: 0.2rem 0.6rem; border-radius: 4px;
  }
  .proj-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--gray-100); }
  .proj-date-small { font-size: 0.75rem; color: var(--gray-500); }

  /* ── SAAS ── */
  #saas { background: var(--dark); color: var(--white); }
  #saas .section-tag { background: rgba(59,130,246,0.2); }
  #saas h2 { color: var(--white); }
  #saas .section-sub { color: rgba(255,255,255,0.6); }
  .saas-card {
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px; padding: 2.5rem; max-width: 800px; margin: 0 auto;
  }
  .saas-badge { display: inline-flex; align-items: center; gap: 0.5rem; background: rgba(26,86,219,0.3); color: #93c5fd; font-size: 0.8rem; font-weight: 700; padding: 0.35rem 1rem; border-radius: 100px; margin-bottom: 1.5rem; }
  .saas-title { font-family: 'DM Serif Display', serif; font-size: 1.8rem; color: var(--white); margin-bottom: 0.75rem; }
  .saas-desc { color: rgba(255,255,255,0.7); line-height: 1.75; margin-bottom: 1.5rem; }
  .saas-features { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem; }
  .saas-feat {
    background: rgba(255,255,255,0.05); border-radius: 10px; padding: 1rem;
    border-left: 3px solid var(--blue-light);
  }
  .saas-feat-icon { font-size: 1.3rem; margin-bottom: 0.3rem; }
  .saas-feat-title { font-size: 0.875rem; font-weight: 600; color: var(--white); }
  .saas-feat-desc { font-size: 0.8rem; color: rgba(255,255,255,0.5); }
  .saas-plans { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
  .saas-plan { background: rgba(255,255,255,0.08); color: #93c5fd; font-size: 0.8rem; font-weight: 700; padding: 0.3rem 1rem; border-radius: 100px; font-family: 'JetBrains Mono', monospace; }
  .saas-stack { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .saas-tech { background: rgba(59,130,246,0.2); color: #93c5fd; font-size: 0.78rem; font-family: 'JetBrains Mono', monospace; padding: 0.25rem 0.7rem; border-radius: 4px; }

  /* ── ARTICLES ── */
  #articles { background: var(--gray-100); }
  .articles-coming {
    background: var(--white); border-radius: 16px; padding: 3rem; text-align: center;
    border: 2px dashed var(--gray-300);
  }
  .articles-coming-icon { font-size: 3rem; margin-bottom: 1rem; }
  .articles-coming-text { font-size: 1rem; color: var(--gray-500); }
  .articles-coming strong { color: var(--dark); }

  /* ── CV ── */
  #cv { background: var(--blue-pale); }
  .cv-box {
    background: var(--white); border-radius: 20px; padding: 3rem;
    text-align: center; box-shadow: 0 4px 24px rgba(26,86,219,0.08);
    max-width: 600px; margin: 0 auto;
  }
  .cv-icon { font-size: 4rem; margin-bottom: 1rem; }
  .cv-title { font-family: 'DM Serif Display', serif; font-size: 1.6rem; color: var(--dark); margin-bottom: 0.75rem; }
  .cv-desc { color: var(--gray-500); margin-bottom: 2rem; }
  .cv-btns { display: flex; justify-content: center; flex-wrap: wrap; gap: 1rem; }

  /* ── CONTACT ── */
  #contact { background: var(--white); }
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
  .contact-form { display: flex; flex-direction: column; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.35rem; }
  .form-group label { font-size: 0.875rem; font-weight: 600; color: var(--dark); }
  .form-group input, .form-group textarea {
    padding: 0.875rem 1rem; border: 1.5px solid var(--gray-300); border-radius: 8px;
    font-family: 'Inter', sans-serif; font-size: 0.9rem; color: var(--dark);
    transition: border-color .2s; background: var(--white);
  }
  .form-group input:focus, .form-group textarea:focus { outline: none; border-color: var(--blue); box-shadow: 0 0 0 3px var(--blue-mid); }
  .form-group textarea { resize: vertical; min-height: 140px; }
  .form-submit { background: var(--blue); color: var(--white); border: none; padding: 0.875rem 2rem; border-radius: 8px; font-weight: 600; font-size: 0.9rem; cursor: pointer; transition: all .2s; align-self: flex-start; }
  .form-submit:hover { background: #1d4ed8; transform: translateY(-1px); }
  .contact-info p { color: var(--gray-700); font-size: 0.975rem; line-height: 1.75; margin-bottom: 1.5rem; }
  .contact-social { display: flex; flex-direction: column; gap: 0.75rem; }

  /* ── FOOTER ── */
  footer {
    background: var(--dark); color: rgba(255,255,255,0.5);
    padding: 2rem 5vw; text-align: center; font-size: 0.85rem;
  }
  footer strong { color: rgba(255,255,255,0.8); }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .fade-up { opacity: 0; animation: fadeUp .6s ease forwards; }
  .delay-1 { animation-delay: .1s; }
  .delay-2 { animation-delay: .2s; }
  .delay-3 { animation-delay: .3s; }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
